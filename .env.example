# Gmail認証（どちらか一方または両方）
GMAIL_IMAP_USER=your-email@gmail.com
GMAIL_IMAP_PASSWORD=your-app-password
GMAIL_IMAP_HOST=imap.gmail.com

# Gmail OAuth（オプション・より安全）
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# Slack通知
SLACK_WEBHOOK_URL_PROD=https://hooks.slack.com/...
SLACK_WEBHOOK_URL_TEST=https://hooks.slack.com/...
SLACK_ERROR_WEBHOOK_URL=https://hooks.slack.com/...
SLACK_DM_WEBHOOK_URL=https://hooks.slack.com/...

# LINE通知
LINE_CHANNEL_ACCESS_TOKEN=
LINE_TO_ID_PROD=
LINE_TO_ID_TEST=

# 動作設定
MODE=test
LOG_DIR=/data
POLL_INTERVAL_SECONDS=60
SEARCH_DAYS=1
